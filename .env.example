# SQL Server connection string used by EF Core
ConnectionStrings__DefaultConnection=Server=YOUR_SERVER;Database=Omnichannel;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;

# JWT settings
Jwt__Key=REPLACE_WITH_32PLUS_CHAR_SECRET_KEY
Jwt__Issuer=Omnichannel
Jwt__Audience=Omnichannel.Client

# VNPay sandbox settings
VNPay__TmnCode=YOUR_TMN_CODE
VNPay__HashSecret=YOUR_HASH_SECRET
VNPay__BaseUrl=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPay__ReturnUrl=https://localhost:7111/api/payment/vnpay-return

# Frontend app URL (for redirects/CORS-dependent flows)
Frontend__BaseUrl=http://localhost:5173

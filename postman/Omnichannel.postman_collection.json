{
  "info": {
    "name": "Omnichannel API",
    "description": "Core API collection for Auth, Perfumes, Orders, Payment, Channels",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5285"
    },
    {
      "key": "jwtToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"postman_user\",\n  \"password\": \"User@123\",\n  \"email\": \"postman@example.com\",\n  \"fullName\": \"Postman User\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password\"\n}"
        }
      }
    },
    {
      "name": "Perfumes - Get All",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/perfumes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "perfumes"
          ]
        }
      }
    },
    {
      "name": "Orders - Place Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwtToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": 2,\n  \"perfumeId\": 1,\n  \"quantity\": 1,\n  \"shippingAddress\": \"123 Nguyen Hue\",\n  \"receiverPhone\": \"0909000000\",\n  \"note\": \"postman\"\n}"
        }
      }
    },
    {
      "name": "Payment - Create VNPay URL",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{baseUrl}}/api/payment/create-payment-url/1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "payment",
            "create-payment-url",
            "1"
          ]
        }
      }
    },
    {
      "name": "Channels - Sync Channel Inventory",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-User-Role",
            "value": "Admin"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwtToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/channels/1/sync",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "channels",
            "1",
            "sync"
          ]
        }
      }
    }
  ]
}
